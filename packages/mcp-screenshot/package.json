{
  "name": "@rchavarria06/mcp-desktop-screenshot",
  "version": "0.1.0",
  "description": "MCP server for macOS desktop screenshots — capture any display or app, switch apps and tabs. Ephemeral by default.",
  "keywords": ["mcp", "screenshot", "macos", "desktop", "claude"],
  "author": "rchavarria06",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-desktop-screenshot": "dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mcp-desktop/core": "*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  }
}
