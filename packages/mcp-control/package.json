{
  "name": "@rchavarria06/mcp-desktop-control",
  "version": "0.1.1",
  "description": "MCP server for macOS desktop control — click, type, scroll, and full screenshot capabilities. Higher trust than mcp-desktop-screenshot.",
  "keywords": [
    "mcp",
    "desktop",
    "control",
    "macos",
    "mouse",
    "keyboard",
    "claude"
  ],
  "author": "rchavarria06",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-desktop-control": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mcp-desktop/core": "*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  }
}
